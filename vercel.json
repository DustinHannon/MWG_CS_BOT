{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm install && cd ChatBot && npm install",
  "buildCommand": "mkdir -p public && cp -r ChatBot/client/* public/",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/health", "destination": "/api" }
  ]
}
